{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "static",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://identity-0ved.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}